{
  "name": "@fulltime/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK + trustless settlement verifier for the Fulltime Solana prediction market (TxLINE-oracle settled).",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "example:verify": "tsx examples/verify-genuine.ts"
  },
  "keywords": [
    "solana",
    "prediction-market",
    "oracle",
    "txline",
    "settlement",
    "verifier",
    "sdk"
  ],
  "dependencies": {
    "bs58": "^5.0.0",
    "js-sha3": "^0.9.3"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.90.0"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.95.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=16"
  }
}
