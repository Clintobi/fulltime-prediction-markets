{
  "name": "fulltime-keeper",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Permissionless auto-settle keeper for the Fulltime Solana prediction market",
  "bin": {
    "fulltime-keeper": "./keeper.mjs"
  },
  "scripts": {
    "start": "node keeper.mjs",
    "once": "node keeper.mjs --once",
    "dry-run": "node keeper.mjs --once --dry-run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0"
  }
}
